# OpenRouter API key — required for LLM chat
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default LLM model — used for Chat / Edit agent
# Options:
#   anthropic/claude-haiku-4-5      ← Claude Haiku 4.5  ($0.80/$2.40 per 1M)
#   anthropic/claude-sonnet-4-5     ← Claude Sonnet 4.5
#   openai/gpt-4o-mini              ← GPT-4o mini       ($0.15/$0.60 per 1M)
DEFAULT_LLM_MODEL=anthropic/claude-haiku-4-5

# Analysis LLM model — used for bulk file analysis (cheaper = better)
# Verified valid model IDs on OpenRouter:
#   google/gemini-2.0-flash-lite-001  ← $0.075/$0.30 per 1M (cheapest)
#   google/gemini-2.5-flash-lite      ← $0.10/$0.40 per 1M
#   openai/gpt-4o-mini                ← $0.15/$0.60 per 1M
ANALYSIS_LLM_MODEL=google/gemini-2.0-flash-lite-001

# OpenRouter base URL (don't change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Custom LLM endpoint — for corporate / on-prem OpenAI-compatible APIs
# Takes priority over Ollama when set. Model name is used as-is (no mapping).
# Example:
#   CUSTOM_LLM_BASE_URL=http://my-llm-server/v1
#   CUSTOM_LLM_API_KEY=my-secret-key
#   DEFAULT_LLM_MODEL=MY_LLM
#   ANALYSIS_LLM_MODEL=MY_LLM
# CUSTOM_LLM_BASE_URL=
# CUSTOM_LLM_API_KEY=none

# Ollama fallback (if no OpenRouter key and no CUSTOM_LLM_BASE_URL)
OLLAMA_BASE_URL=http://localhost:11434

# Set to true to bypass shell command allowlist (dev only — use with caution)
# AGENT_SHELL_UNRESTRICTED=false

# Benchmark model selector — shows a dropdown in ChatBar to override the LLM per query.
# Format: comma-separated "model-id:Display Name" pairs.
# Leave empty (or unset) to hide the dropdown entirely.
# Example:
# VITE_BENCHMARK_MODELS=z-ai/glm-5:GLM-5,moonshotai/kimi-k2.5:Kimi K2.5,anthropic/claude-opus-4-5:Opus 4.5
# VITE_BENCHMARK_MODELS=
